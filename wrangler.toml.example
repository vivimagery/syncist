name = "syncist"
main = "src/index.ts"
compatibility_date = "2023-01-01"

[vars]
# Optional: Filter syncing to only issues assigned to a specific user
# Uncomment and set to your Linear user ID to enable filtering
# LINEAR_ASSIGNEE_ID = "your-linear-user-id-here"

# Required: Supabase configuration
SUPABASE_URL = "your-supabase-url-here"
SUPABASE_PUBLIC_KEY = "your-supabase-public-key-here"

# Note: Sensitive secrets like LINEAR_API_KEY and TODOIST_API_KEY 
# should NOT be stored in this file. Set them as secrets using:
# wrangler secret put LINEAR_API_KEY
# wrangler secret put TODOIST_API_KEY

# To use this file:
# 1. Copy this file to wrangler.toml: cp wrangler.toml.example wrangler.toml
# 2. Replace the placeholder values with your actual configuration
# 3. Uncomment and set LINEAR_ASSIGNEE_ID if you want to filter by assignee
# 4. Set your secrets using the wrangler secret commands above
